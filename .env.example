# Copia este archivo a `.env` y completa con tus valores reales.
# `.env` está en .gitignore — NUNCA se versiona.
# Los valores hardcodeados en config.py se usan como fallback si la variable no está definida.

# --- Google Sheets ---
# Ruta al service account JSON (relativa a la raíz del proyecto)
GOOGLE_CREDENTIALS_PATH=secrets/google_service_account.json

# IDs de Google Sheets (ver URL del spreadsheet: /d/<ID>/edit)
SHEETS_ID_KPI=<id-sheet-kpi>
SHEETS_ID_CEDULAS=<id-sheet-cedula-dg>

# --- Rutas locales ---
DATA_INPUT_DIR=data-input
OUTPUTS_DIR=Outputs

# --- Logging ---
# ERROR | INFO | DEBUG
LOG_LEVEL=INFO

# --- SAP (opcional, solo si usas extract_zvpf) ---
SAP_USERNAME=
SAP_PASSWORD=
SAP_SYSTEM=

# --- Fuente de cédulas: db | excel | sheets ---
# Default "db". Si la BD es inaccesible y FALLBACK_ON_DB_ERROR=true,
# la cadena de fallback es: db → sheets → excel.
CEDULAS_SOURCE=db

# Si CEDULAS_SOURCE=db falla: true = fallback automático db → sheets → excel
# Recomendado en máquinas sin VPN Valle Dorado (ej. Yanet).
FALLBACK_ON_DB_ERROR=false
FALLBACK_CEDULAS_PATH=data-input/Cedulas

# --- PostgreSQL Cédula DG ---
# Requiere VPN Valle Dorado activa. Credenciales en proyecto Cedula DG (.env).
PG_CEDULA_HOST=<ip-o-hostname-postgres>
PG_CEDULA_PORT=5432
PG_CEDULA_DB=<nombre-base-de-datos>
PG_CEDULA_USER=<usuario-postgres>
PG_CEDULA_PASSWORD=<contraseña-postgres>
PG_CEDULA_SCHEMA=public
PG_CEDULA_TABLE=cedula_unidades
PG_CONNECT_TIMEOUT=10
# Timeout para una query individual (ms). Corta queries colgadas.
PG_STATEMENT_TIMEOUT_MS=60000
