# Copia este archivo a `.env` y completa con tus valores reales.
# `.env` está en .gitignore — NUNCA se versiona.

# --- Google Sheets ---
# Ruta al service account JSON (relativa a la raíz del proyecto)
GOOGLE_CREDENTIALS_PATH=secrets/google_service_account.json

# IDs de Google Sheets destino
SHEETS_ID_KPI=1sv8P004Ej85D_GF4YwEmoBO1XqWR1KYdGOSb1FJWM8Y
SHEETS_ID_CEDULAS=18lw2_Rv-j_vwXTwXXGKX5-BZ_8t8MNfz6IHuLaIKBf0

# --- Rutas locales ---
DATA_INPUT_DIR=data-input
OUTPUTS_DIR=Outputs

# --- Logging ---
# ERROR | INFO | DEBUG
LOG_LEVEL=INFO

# --- SAP (opcional, solo si usas extract_zvpf) ---
SAP_USERNAME=
SAP_PASSWORD=
SAP_SYSTEM=

# --- Fuente de cédulas: db | excel | sheets ---
# Default "db" desde v0.3.0. Usa "excel" como fallback manual si la BD está caída
# (también puedes activar FALLBACK_ON_DB_ERROR=true para que el fallback sea automático).
CEDULAS_SOURCE=db

# Si CEDULAS_SOURCE=db falla, ¿usar fallback a Excel automáticamente?
FALLBACK_ON_DB_ERROR=false
FALLBACK_CEDULAS_PATH=data-input/Cedulas

# --- PostgreSQL Cédula DG (172.17.1.4 / cedula_direccion) ---
# Requiere VPN Valle Dorado activa. Credenciales en proyecto Cedula DG.
PG_CEDULA_HOST=172.17.1.4
PG_CEDULA_PORT=5432
PG_CEDULA_DB=cedula_direccion
PG_CEDULA_USER=
PG_CEDULA_PASSWORD=
PG_CEDULA_SCHEMA=public
PG_CEDULA_TABLE=cedula_unidades
PG_CONNECT_TIMEOUT=10
# Timeout para una query individual (ms). Corta queries colgadas.
PG_STATEMENT_TIMEOUT_MS=60000
